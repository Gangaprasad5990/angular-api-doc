{
  "name": "angular-api-doc",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo-app",
    "build": "ng build",
    "build:docuify": "ng build docuify && npm run build:styles && npm run postbuild",
    "build:styles": "sass projects/docuify/src/lib/styles/styles.scss | postcss --config postcss.config.js -o dist/docuify/lib/styles.css",
    "postbuild": "copyFiles -f dist/docuify/lib/styles.css node_modules/docuify",
    "watch:styles": "sass --watch projects/docuify/src/lib/styles/styles.scss:dist/docuify/lib/styles.css --style=compressed",
    "watch:lib": "ng build docuify --watch",
    "watch:postbuild": "copyFiles -f 'dist/docuify/lib/styles.css' -c 'npm run postbuild'",
    "watch": "npm-run-all --parallel watch:lib watch:styles watch:postbuild",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.2.0",
    "@angular/common": "^17.2.0",
    "@angular/compiler": "^17.2.0",
    "@angular/core": "^17.2.0",
    "@angular/forms": "^17.2.0",
    "@angular/platform-browser": "^17.2.0",
    "@angular/platform-browser-dynamic": "^17.2.0",
    "@angular/platform-server": "^17.2.0",
    "@angular/router": "^17.2.0",
    "@angular/ssr": "^17.2.0",
    "express": "^4.18.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.11",
    "@angular/cli": "^17.2.0",
    "@angular/compiler-cli": "^17.2.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "autoprefixer": "^10.4.20",
    "copyfiles": "^2.4.1",
    "cssnano": "^7.0.6",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^17.3.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "sass": "^1.83.1",
    "typescript": "~5.3.2"
  }
}
